# Copy to .env and fill in values

MONGO_URI=mongodb://127.0.0.1:27017/project

# The part after the last "/" is the DATABASE name in Compass (e.g. "project").
# If you omit it (mongodb://127.0.0.1:27017), MongoDB uses "test" — open THAT db in Compass or add /yourdbname here.

# Admin JWT signing. In development, if unset or under 16 chars the server uses a built-in default (see middleware/auth.js). Production requires a strong secret here.
JWT_SECRET=change_this_to_a_random_string_at_least_16_chars

# Optional token lifetime (default 7d)
# JWT_EXPIRES_IN=7d

PORT=5000

# Stripe (optional — card checkout). Use keys from the same Stripe account (Dashboard → Developers → API keys).
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_PUBLISHABLE_KEY=pk_test_...
